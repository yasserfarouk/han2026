# HANI Environment Configuration
# ================================
# Copy this file to .env and modify the values for your environment.
# The .env file is loaded automatically when the app starts.

# =============================================================================
# AUTHENTICATION
# =============================================================================

# Admin password for the 'admin' user (used in password auth mode)
# IMPORTANT: Change this to a secure password in production!
ADMIN_PASS=admin

# Admin emails for OAuth mode (comma-separated list)
# Users with these emails will have admin access when using OAuth authentication
ADMIN_EMAILS=yasserfarouk@gmail.com

# Authentication Mode
# Options:
#   - 'auto'     : Uses OAuth if credentials are set, otherwise password (default)
#   - 'password' : Always use password authentication (good for local development)
#   - 'oauth'    : Always use OAuth (requires OAuth credentials below)
HANI_AUTH_MODE=password

# =============================================================================
# OAUTH CONFIGURATION (Required if HANI_AUTH_MODE=oauth)
# =============================================================================

# OAuth Provider: github, google, azure, okta, etc.
# HANI_OAUTH_PROVIDER=github

# OAuth Client ID (from your OAuth provider)
# HANI_OAUTH_KEY=your-oauth-client-id

# OAuth Client Secret (from your OAuth provider)
# HANI_OAUTH_SECRET=your-oauth-client-secret

# OAuth Redirect URI (must match what you configured in the OAuth provider)
# HANI_OAUTH_REDIRECT_URI=http://localhost:5006

# OAuth Encryption Key (generate with: python -c "import secrets; print(secrets.token_urlsafe(32))")
# HANI_OAUTH_ENCRYPTION_KEY=your-32-byte-base64-key

# =============================================================================
# SESSION & SECURITY
# =============================================================================

# Cookie Secret for session management
# IMPORTANT: Change this to a random string in production!
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
HANI_COOKIE_SECRET=hani-super-secret-co-4653322hjhj

# =============================================================================
# LLM CONFIGURATION (for Response Generator & Outcome Extraction)
# =============================================================================

# OpenAI API Key (if using OpenAI as the LLM provider)
# Get your key at: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-your-openai-api-key-here

# Anthropic API Key (if using Anthropic/Claude as the LLM provider)
# Get your key at: https://console.anthropic.com/
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here

# =============================================================================
# ENVIRONMENT
# =============================================================================

# Environment mode: 'local' or 'production'
# Affects URL configuration and other environment-specific settings
HANI_ENV=local

# =============================================================================
# QUICK START EXAMPLES
# =============================================================================
#
# LOCAL DEVELOPMENT (password auth):
# -----------------------------------
# ADMIN_PASS=mydevpassword
# HANI_AUTH_MODE=password
# OPENAI_API_KEY=sk-...  # Optional, for LLM features
#
# PRODUCTION (OAuth with GitHub):
# --------------------------------
# HANI_AUTH_MODE=oauth
# HANI_OAUTH_PROVIDER=github
# HANI_OAUTH_KEY=Iv1.abc123...
# HANI_OAUTH_SECRET=abc123...
# HANI_OAUTH_REDIRECT_URI=https://your-domain.com
# HANI_OAUTH_ENCRYPTION_KEY=<generate-random-key>
# HANI_COOKIE_SECRET=<generate-random-key>
# HANI_ENV=production
# OPENAI_API_KEY=sk-...
#
# =============================================================================
